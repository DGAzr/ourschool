# OurSchool Environment Configuration
# Copy this file to .env and update the values for your environment

# =============================================================================
# IMAGE TAG (docker-compose.ghcr.yml only)
# =============================================================================
# Controls which GHCR release to pull. Must match a tag published at:
#   https://github.com/DGAzr/ourschool/pkgs/container/ourschool-backend
# Examples: v1.0.0-beta.9  v1.1.0  dev (latest dev build)
IMAGE_TAG=v1.0.0-beta.9


# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Choose ONE of the two options below:
#
# Option A — Local PostgreSQL (managed by Docker Compose)
#   Run with: docker compose -f docker-compose.ghcr.yml --profile local-db up -d
#   Leave DATABASE_URL commented out and configure the POSTGRES_* vars.
#
# Option B — External PostgreSQL (your own server, managed service, etc.)
#   Run with: docker compose -f docker-compose.ghcr.yml up -d  (no --profile flag)
#   Set DATABASE_URL to your connection string and leave POSTGRES_* vars blank.
# =============================================================================

# Option A: Individual connection settings (used when DATABASE_URL is not set)
POSTGRES_DB=ourschool
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_PORT=5432

# Option B: Full connection URL (takes precedence over individual vars above)
# Supports any valid PostgreSQL URL — local, RDS, Supabase, Neon, etc.
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Advanced: override individual backend connection settings without a full URL.
# These are only needed if your external DB uses different credentials than
# the POSTGRES_* vars above.
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=ourschool
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your-secure-password-here


# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Generate a strong key with: openssl rand -hex 32
# The app refuses to start if this is unset. Do NOT use the placeholder above in production.
SECRET_KEY=your-very-secure-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Absolute maximum session lifetime in minutes. Sessions can be extended by
# activity, but never past this cap. Default: 720 (12 hours).
# MAX_SESSION_AGE_MINUTES=720

# Maximum accepted request body size in bytes. Protects memory-heavy endpoints
# such as backup import from oversized payloads. Default: 10485760 (10 MiB).
# Raise this if restoring a very large backup file is rejected with HTTP 413.
# MAX_REQUEST_BODY_BYTES=10485760

# Interactive API docs (/docs, /redoc, /openapi.json). Disabled by default so
# a fresh deploy doesn't publish the API schema. Uncomment to enable.
# ENABLE_API_DOCS=true


# =============================================================================
# NETWORK BINDING
# =============================================================================
# Which host interface each published port binds to.
# The frontend (port 4173) is the only service meant to be reachable from
# other machines; the backend and database bind to loopback by default and
# are reached through the frontend's nginx proxy.
#
# Only set the *_BIND values to 0.0.0.0 if you know you need direct external
# access (e.g. the backend behind your own TLS reverse proxy).
# BACKEND_BIND=127.0.0.1
# POSTGRES_BIND=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=4173


# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# LOG_LEVEL sets the default level for all services.
# BACKEND_LOG_LEVEL overrides it for the backend container only.
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
#
# LOG_FORMAT controls backend log output format: json (default) or text
#
# Examples:
#   Production:  LOG_LEVEL=INFO  LOG_FORMAT=json
#   Development: LOG_LEVEL=DEBUG LOG_FORMAT=text
#   Quiet:       LOG_LEVEL=WARNING
LOG_LEVEL=INFO
LOG_FORMAT=json

# Per-service overrides (uncomment to use)
# BACKEND_LOG_LEVEL=DEBUG
# BACKEND_LOG_FORMAT=text

# Optional: write backend logs to a file in addition to stdout
# LOG_FILE=/var/log/ourschool/app.log


# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173,http://localhost:3000,http://frontend:4173

# NOTE on VITE_API_BASE_URL: the frontend's API base URL is baked in at BUILD
# time, not read at runtime. Pre-built GHCR images use "/api", which nginx
# proxies to the backend — no configuration needed. Setting VITE_API_BASE_URL
# here has no effect unless you build the frontend from source yourself.
